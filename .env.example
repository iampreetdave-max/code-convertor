# Copy this file to .env and fill in your real values.
# .env is gitignored and must never be committed.

# Groq API key(s) — power the AI code conversion + validation.
# Get keys at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL extra keys for more headroom + failover. Each free key has its own
# tokens/min budget, so adding these ~multiplies capacity and keeps converting if
# one key is rate-limited or dies. Use separate Groq accounts for independent quotas.
# GROQ_API_KEY_2=your_second_groq_api_key
# GROQ_API_KEY_3=your_third_groq_api_key
# (Alternatively, one comma-separated list: GROQ_API_KEYS=key1,key2,key3)
